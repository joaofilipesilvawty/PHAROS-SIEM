# Runtime: JRuby + OJDBC (lib/ojdbc8-*.jar) — ver .ruby-version
# --- Servidor ---
HOST=127.0.0.1
PORT=4567
LOG_LEVEL=info

# --- Oracle Database (usado em server.rb / Sequel) ---
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=XEPDB1
ORACLE_USERNAME=siem
ORACLE_PASSWORD=changeme

# --- Segurança / sessão ---
# Descomenta e preenche (recomendado em produção):
# SESSION_SECRET=   # openssl rand -hex 32
# ADMIN_PASSWORD=   # bootstrap do user admin na primeira BD vazia
# INGEST_API_KEY=   # POST /logs com header X-API-Key (obrigatório se usares a API sem JWT)

# --- Redis (opcional: rate limit, API keys em redis) ---
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# --- API JWT (opcional) ---
# API_JWT_SECRET=

# --- Integrações / monitorização (opcionais) ---
MONITORING_INTERVAL=60
NETWORK_DATA_SOURCE_ENABLED=false
ENDPOINT_DATA_SOURCE_ENABLED=false
CLOUD_DATA_SOURCE_ENABLED=false

# --- VirusTotal (opcional) ---
THREAT_FEED_VIRUSTOTAL_URL=https://www.virustotal.com/vtapi/v2/file/report
THREAT_FEED_VIRUSTOTAL_KEY=

# --- Retenção / políticas (referência; parte ainda não ligada ao código) ---
LOG_RETENTION_DURATION_DAYS=90
LOG_RETENTION_AUTO_PURGE=false
