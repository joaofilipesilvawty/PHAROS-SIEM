# -----------------------------------------------------------------------------
# Servidor HTTP
# -----------------------------------------------------------------------------
HOST=127.0.0.1
PORT=4567
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Oracle Database (Sequel / server.rb)
# -----------------------------------------------------------------------------
