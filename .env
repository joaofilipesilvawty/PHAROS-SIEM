# =============================================================================
# SIEM — variáveis de ambiente
# Runtime: JRuby + Oracle (OJDBC em lib/). Ver .ruby-version
# =============================================================================

# -----------------------------------------------------------------------------
# Servidor HTTP
# -----------------------------------------------------------------------------
HOST=127.0.0.1
PORT=4567
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Oracle Database (Sequel / server.rb)
# -----------------------------------------------------------------------------
ORACLE_HOST=127.0.0.1
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=FREEPDB1
ORACLE_USERNAME=joaofilipesilva
ORACLE_PASSWORD=joaofilipegsilva

# -----------------------------------------------------------------------------
# Elasticsearch (logs, métricas, pesquisa — integração na app quando ligares)
# -----------------------------------------------------------------------------
ELASTICSEARCH_HOST=127.0.0.1
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=joaofilipegsilva
ELASTICSEARCH_INDEX_PREFIX=siem
# Verificar certificado TLS em produção (true/false)
ELASTICSEARCH_SSL_VERIFY=true

# -----------------------------------------------------------------------------
# Redis (rate limit, API keys — opcional)
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Segurança da aplicação
# Descomenta em produção:
# SESSION_SECRET=          # openssl rand -hex 32
# ADMIN_PASSWORD=        # bootstrap admin se tabela admins vazia
# INGEST_API_KEY=        # header X-API-Key para POST /logs
# API_JWT_SECRET=        # Bearer JWT na API

# -----------------------------------------------------------------------------
# API / limites (APISecurity)
# -----------------------------------------------------------------------------
# API_RATE_LIMIT_MAX_REQUESTS=100
# API_RATE_LIMIT_WINDOW=60
# API_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Fontes de dados / monitorização (placeholders do server.rb)
# -----------------------------------------------------------------------------
MONITORING_INTERVAL=60
NETWORK_DATA_SOURCE_ENABLED=false
NETWORK_DATA_SOURCE_HOST=
ENDPOINT_DATA_SOURCE_ENABLED=false
ENDPOINT_DATA_SOURCE_HOST=
CLOUD_DATA_SOURCE_ENABLED=false
CLOUD_DATA_SOURCE_API_KEY=
# XDR_INTEGRATION_ENABLED=false
# XDR_INTEGRATION_ENDPOINT=
# XDR_INTEGRATION_API_KEY=
# DLP_INTEGRATION_ENABLED=false
# DLP_INTEGRATION_ENDPOINT=
# DLP_INTEGRATION_API_KEY=
# MFA_INTEGRATION_ENABLED=false
# MFA_INTEGRATION_PROVIDER=
# MFA_INTEGRATION_CONFIG=
