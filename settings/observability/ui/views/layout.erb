<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>OPSMON</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <% path = request.path_info %>
  <div class="gf-app">
    <aside class="gf-sidenav" aria-label="Navegação principal">
      <div class="gf-sidenav-brand">OPSMON <span>·</span> consola</div>
      <ul class="gf-sidenav-nav">
        <li>
          <a class="gf-nav-link<%= ' is-active' if path == '/dashboard' %>" href="/dashboard">
            <i data-feather="home"></i>
            Dashboard
          </a>
        </li>
        <li>
          <a class="gf-nav-link<%= ' is-active' if path.start_with?('/dashboard/alerts') %>" href="/dashboard/alerts">
            <i data-feather="alert-triangle"></i>
            Alertas
          </a>
        </li>
        <li>
          <a class="gf-nav-link<%= ' is-active' if path.start_with?('/dashboard/logs') %>" href="/dashboard/logs">
            <i data-feather="file-text"></i>
            Logs
          </a>
        </li>
        <li>
          <a class="gf-nav-link<%= ' is-active' if path.start_with?('/dashboard/metrics') %>" href="/dashboard/metrics">
            <i data-feather="bar-chart-2"></i>
            Métricas
          </a>
        </li>
        <li>
          <a class="gf-nav-link<%= ' is-active' if path.start_with?('/dashboard/reports') %>" href="/dashboard/reports">
            <i data-feather="printer"></i>
            Relatórios
          </a>
        </li>
        <li>
          <a class="gf-nav-link<%= ' is-active' if path.start_with?('/dashboard/settings') %>" href="/dashboard/settings">
            <i data-feather="settings"></i>
            Configurações
          </a>
        </li>
        <li>
          <a class="gf-nav-link<%= ' is-active' if path.start_with?('/dashboard/profile') %>" href="/dashboard/profile">
            <i data-feather="user"></i>
            Perfil
          </a>
        </li>
        <li>
          <a class="gf-nav-link" href="/auth/logout">
            <i data-feather="log-out"></i>
            Sair
          </a>
        </li>
      </ul>
    </aside>

    <div class="gf-main">
      <header class="gf-topbar">
        <div class="gf-breadcrumb">
          Monitorização · <strong>OPSMON</strong>
        </div>
      </header>
      <div class="gf-content">
        <%= yield %>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/feather-icons/dist/feather.min.js"></script>
  <script>feather.replace();</script>
</body>
</html>
