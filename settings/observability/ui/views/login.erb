<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Entrar · OPSMON</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="gf-auth-page">
  <div class="gf-auth-card">
    <div class="gf-auth-card-h">
      <h1>OPSMON</h1>
      <p>Inicia sessão na consola de segurança</p>
    </div>
    <div class="gf-auth-card-b">
      <% if @error %>
        <div class="gf-alert-error" role="alert"><%= @error %></div>
      <% end %>

      <form action="/auth/login" method="post">
        <div class="gf-form-field">
          <label class="gf-form-label" for="username">Utilizador</label>
          <input type="text" class="gf-form-input" id="username" name="username" required autocomplete="username">
        </div>
        <div class="gf-form-field">
          <label class="gf-form-label" for="password">Palavra-passe</label>
          <input type="password" class="gf-form-input" id="password" name="password" required autocomplete="current-password">
        </div>
        <button type="submit" class="gf-btn-primary">Entrar</button>
      </form>

      <div class="gf-auth-foot">
        Acesso reservado a administradores
      </div>
    </div>
  </div>
</body>
</html>
