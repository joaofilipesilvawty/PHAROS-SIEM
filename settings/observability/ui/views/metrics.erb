<div class="gf-page-head">
  <h1>Métricas</h1>
  <a class="gf-btn" href="/dashboard">← Dashboard</a>
</div>

<p class="gf-help">Últimos valores gravados por tipo (Oracle).</p>

<% (@metrics || {}).each do |name, samples| %>
  <div class="gf-panel">
    <div class="gf-panel-h"><%= name %></div>
    <div class="gf-panel-b">
      <% if samples.nil? || samples.empty? %>
        <p class="gf-empty">Sem dados</p>
      <% else %>
        <ul class="gf-metric-list">
          <% samples.first(5).each do |row| %>
            <li>
              <code class="gf-code"><%= row['timestamp'] || row[:timestamp] %></code>
              <span class="gf-metric-val"><%= row['value'] || row[:value] %></span>
              <span class="gf-metric-src">(<%= row['source'] || row[:source] %>)</span>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>
  </div>
<% end %>
