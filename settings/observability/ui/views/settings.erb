<div class="gf-page-head">
  <h1>Configurações</h1>
  <a class="gf-btn" href="/dashboard">← Dashboard</a>
</div>

<div class="gf-panel">
  <div class="gf-panel-h">Aplicação</div>
  <div class="gf-panel-b">
    <p class="gf-field-label">Nível de log</p>
    <p class="gf-profile-line"><code class="gf-code"><%= @settings && @settings[:log_level] %></code></p>

    <p class="gf-field-label gf-field-label--spaced">Limiares de alerta</p>
    <pre class="gf-pre"><%= ERB::Util.html_escape((@settings[:alert_thresholds] || {}).inspect) %></pre>
  </div>
</div>
