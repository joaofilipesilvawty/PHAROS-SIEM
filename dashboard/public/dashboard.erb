<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
  <h1 class="h2">Dashboard</h1>
  <div class="btn-toolbar mb-2 mb-md-0">
    <div class="btn-group me-2">
      <button type="button" class="btn btn-sm btn-outline-secondary">Hoje</button>
      <button type="button" class="btn btn-sm btn-outline-secondary">Semana</button>
      <button type="button" class="btn btn-sm btn-outline-secondary">Mês</button>
    </div>
  </div>
</div>

<div class="row">
  <!-- Alertas -->
  <div class="col-md-3 mb-4">
    <div class="card text-white bg-danger">
      <div class="card-body">
        <h5 class="card-title">Alertas Críticos</h5>
        <p class="card-text display-4"><%= @metrics[:critical_count] %></p>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-4">
    <div class="card text-white bg-warning">
      <div class="card-body">
        <h5 class="card-title">Alertas Altos</h5>
        <p class="card-text display-4"><%= @metrics[:high_count] %></p>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-4">
    <div class="card text-white bg-info">
      <div class="card-body">
        <h5 class="card-title">Alertas Médios</h5>
        <p class="card-text display-4"><%= @metrics[:medium_count] %></p>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-4">
    <div class="card text-white bg-secondary">
      <div class="card-body">
        <h5 class="card-title">Alertas Baixos</h5>
        <p class="card-text display-4"><%= @metrics[:low_count] %></p>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <!-- Gráficos -->
  <div class="col-md-6 mb-4">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title">Uso de Recursos</h5>
      </div>
      <div class="card-body">
        <canvas id="resourcesChart" width="400" height="200"></canvas>
      </div>
    </div>
  </div>
  <div class="col-md-6 mb-4">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title">Atividade por Hora</h5>
      </div>
      <div class="card-body">
        <canvas id="activityChart" width="400" height="200"></canvas>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <!-- Últimos Alertas -->
  <div class="col-md-6 mb-4">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title">Últimos Alertas</h5>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-striped table-sm">
            <thead>
              <tr>
                <th>Data</th>
                <th>Tipo</th>
                <th>Severidade</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% @alerts.each do |alert| %>
                <tr>
                  <td><%= alert[:timestamp].strftime("%Y-%m-%d %H:%M") %></td>
                  <td><%= alert[:alert_type] %></td>
                  <td><%= alert[:severity] %></td>
                  <td><%= alert[:status] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Últimos Logs -->
  <div class="col-md-6 mb-4">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title">Últimos Logs</h5>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-striped table-sm">
            <thead>
              <tr>
                <th>Data</th>
                <th>Tipo</th>
                <th>Usuário</th>
                <th>IP</th>
              </tr>
            </thead>
            <tbody>
              <% @logs.each do |log| %>
                <tr>
                  <td><%= log[:timestamp].strftime("%Y-%m-%d %H:%M") %></td>
                  <td><%= log[:event_type] %></td>
                  <td><%= log[:user_id] %></td>
                  <td><%= log[:ip_address] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Gráfico de Recursos
  new Chart(document.getElementById('resourcesChart'), {
    type: 'line',
    data: {
      labels: ['CPU', 'Memória', 'Disco'],
      datasets: [{
        label: 'Uso (%)',
        data: [
          <%= @metrics[:cpu_usage] %>,
          <%= @metrics[:memory_usage] %>,
          <%= @metrics[:disk_usage] %>
        ],
        backgroundColor: [
          'rgba(255, 99, 132, 0.2)',
          'rgba(54, 162, 235, 0.2)',
          'rgba(255, 206, 86, 0.2)'
        ],
        borderColor: [
          'rgba(255, 99, 132, 1)',
          'rgba(54, 162, 235, 1)',
          'rgba(255, 206, 86, 1)'
        ],
        borderWidth: 1
      }]
    },
    options: {
      scales: {
        y: {
          beginAtZero: true,
          max: 100
        }
      }
    }
  });

  // Gráfico de Atividade
  new Chart(document.getElementById('activityChart'), {
    type: 'line',
    data: {
      labels: <%= @activity_timeline[:labels].to_json %>,
      datasets: [{
        label: 'Eventos por Hora',
        data: <%= @activity_timeline[:data].to_json %>,
        fill: false,
        borderColor: 'rgb(75, 192, 192)',
        tension: 0.1
      }]
    }
  });
</script>