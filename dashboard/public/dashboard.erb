<div class="gf-page-head">
  <h1>Dashboard</h1>
  <div class="gf-btn-group" title="Filtro de intervalo — por implementar">
    <span class="gf-btn is-active">Hoje</span>
    <span class="gf-btn">Semana</span>
    <span class="gf-btn">Mês</span>
  </div>
</div>

<div class="gf-row gf-row-4">
  <div class="gf-stat gf-stat--critical">
    <div class="gf-stat-label">Críticos</div>
    <div class="gf-stat-value"><%= @metrics[:critical_count] %></div>
  </div>
  <div class="gf-stat gf-stat--high">
    <div class="gf-stat-label">Altos</div>
    <div class="gf-stat-value"><%= @metrics[:high_count] %></div>
  </div>
  <div class="gf-stat gf-stat--medium">
    <div class="gf-stat-label">Médios</div>
    <div class="gf-stat-value"><%= @metrics[:medium_count] %></div>
  </div>
  <div class="gf-stat gf-stat--low">
    <div class="gf-stat-label">Baixos</div>
    <div class="gf-stat-value"><%= @metrics[:low_count] %></div>
  </div>
</div>

<div class="gf-row gf-row-2">
  <div class="gf-panel">
    <div class="gf-panel-h">Uso de recursos (%)</div>
    <div class="gf-panel-b">
      <canvas id="resourcesChart" height="200"></canvas>
    </div>
  </div>
  <div class="gf-panel">
    <div class="gf-panel-h">Atividade por hora</div>
    <div class="gf-panel-b">
      <canvas id="activityChart" height="200"></canvas>
    </div>
  </div>
</div>

<div class="gf-row gf-row-2">
  <div class="gf-panel">
    <div class="gf-panel-h">Últimos alertas</div>
    <div class="gf-panel-b gf-table-wrap">
      <table class="gf-table">
        <thead>
          <tr>
            <th>Data</th>
            <th>Tipo</th>
            <th>Severidade</th>
            <th>Estado</th>
          </tr>
        </thead>
        <tbody>
          <% @alerts.each do |alert| %>
            <tr>
              <td><%= alert[:timestamp].strftime("%Y-%m-%d %H:%M") %></td>
              <td><%= alert[:alert_type] %></td>
              <td><%= alert[:severity] %></td>
              <td><%= alert[:status] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="gf-panel">
    <div class="gf-panel-h">Últimos logs</div>
    <div class="gf-panel-b gf-table-wrap">
      <table class="gf-table">
        <thead>
          <tr>
            <th>Data</th>
            <th>Tipo</th>
            <th>Utilizador</th>
            <th>IP</th>
          </tr>
        </thead>
        <tbody>
          <% @logs.each do |log| %>
            <tr>
              <td><%= log[:timestamp].strftime("%Y-%m-%d %H:%M") %></td>
              <td><%= log[:event_type] %></td>
              <td><%= log[:user_id] %></td>
              <td><%= log[:ip_address] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
<script>
(function () {
  var muted = '#8b8c9a';
  var grid = '#2d2d38';
  var purple = '#8b5cf6';
  var purpleSoft = 'rgba(139, 92, 246, 0.25)';
  var violet = '#a78bfa';

  Chart.defaults.color = muted;
  Chart.defaults.borderColor = grid;
  Chart.defaults.font.family = "system-ui, sans-serif";

  new Chart(document.getElementById('resourcesChart'), {
    type: 'bar',
    data: {
      labels: ['CPU', 'Memória', 'Disco'],
      datasets: [{
        label: 'Uso %',
        data: [
          <%= @metrics[:cpu_usage] %>,
          <%= @metrics[:memory_usage] %>,
          <%= @metrics[:disk_usage] %>
        ],
        backgroundColor: [purpleSoft, 'rgba(167, 139, 250, 0.2)', 'rgba(124, 58, 237, 0.2)'],
        borderColor: [purple, violet, '#7c3aed'],
        borderWidth: 1
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: { legend: { display: false } },
      scales: {
        y: {
          beginAtZero: true,
          max: 100,
          grid: { color: grid },
          ticks: { color: muted }
        },
        x: {
          grid: { display: false },
          ticks: { color: muted }
        }
      }
    }
  });

  new Chart(document.getElementById('activityChart'), {
    type: 'line',
    data: {
      labels: <%= @activity_timeline[:labels].to_json %>,
      datasets: [{
        label: 'Eventos / hora',
        data: <%= @activity_timeline[:data].to_json %>,
        fill: true,
        backgroundColor: 'rgba(124, 58, 237, 0.12)',
        borderColor: purple,
        borderWidth: 2,
        tension: 0.2,
        pointRadius: 0,
        pointHoverRadius: 4
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: { legend: { display: false } },
      scales: {
        y: {
          beginAtZero: true,
          grid: { color: grid },
          ticks: { color: muted }
        },
        x: {
          grid: { color: grid },
          ticks: { color: muted, maxRotation: 45, minRotation: 0 }
        }
      }
    }
  });
})();
</script>
