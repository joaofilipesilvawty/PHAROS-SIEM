<div class="gf-page-head">
  <h1>Relatórios</h1>
  <a class="gf-btn" href="/dashboard">← Dashboard</a>
</div>

<div class="gf-panel">
  <div class="gf-panel-h">Tipos de relatório</div>
  <div class="gf-panel-b" style="padding: 0;">
    <ul class="list-group">
      <% (@report_types || []).each do |r| %>
        <li class="list-group-item">
          <span><%= r[:name] %></span>
          <span class="badge"><%= r[:id] %></span>
        </li>
      <% end %>
    </ul>
  </div>
</div>

<p class="gf-help gf-help--tight">Geração exportável ainda não implementada — apenas lista de tipos planeados.</p>
