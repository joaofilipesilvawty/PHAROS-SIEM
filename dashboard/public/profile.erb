<div class="gf-page-head">
  <h1>Perfil</h1>
  <a class="gf-btn" href="/dashboard">← Dashboard</a>
</div>

<% if @admin %>
  <div class="gf-panel">
    <div class="gf-panel-h">Conta</div>
    <div class="gf-panel-b">
      <p class="gf-profile-line"><strong>ID</strong> <code class="gf-code"><%= @admin.id %></code></p>
      <p class="gf-profile-line"><strong>Utilizador</strong> <%= @admin.username %></p>
    </div>
  </div>
<% else %>
  <p class="text-danger">Sessão inválida.</p>
<% end %>
