<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
  <h1 class="h2">Alertas</h1>
  <a class="btn btn-sm btn-outline-secondary" href="/dashboard">Voltar</a>
</div>

<div class="table-responsive">
  <table class="table table-striped table-sm">
    <thead>
      <tr>
        <th>Data</th>
        <th>Tipo</th>
        <th>Severidade</th>
        <th>Mensagem</th>
        <th>Estado</th>
      </tr>
    </thead>
    <tbody>
      <% (@alerts || []).each do |alert| %>
        <tr>
          <td><%= alert[:timestamp] ? alert[:timestamp].strftime('%Y-%m-%d %H:%M') : '-' %></td>
          <td><%= alert[:alert_type] %></td>
          <td><%= alert[:severity] %></td>
          <td><%= alert[:message].to_s[0, 80] %><%= alert[:message].to_s.length > 80 ? '…' : '' %></td>
          <td><%= alert[:status] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
