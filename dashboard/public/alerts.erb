<div class="gf-page-head">
  <h1>Alertas</h1>
  <a class="gf-btn" href="/dashboard">← Dashboard</a>
</div>

<div class="gf-panel">
  <div class="gf-panel-h">Todos os alertas</div>
  <div class="gf-panel-b gf-table-wrap">
    <table class="gf-table">
      <thead>
        <tr>
          <th>Data</th>
          <th>Tipo</th>
          <th>Severidade</th>
          <th>Mensagem</th>
          <th>Estado</th>
        </tr>
      </thead>
      <tbody>
        <% (@alerts || []).each do |alert| %>
          <tr>
            <td><%= alert[:timestamp] ? alert[:timestamp].strftime('%Y-%m-%d %H:%M') : '-' %></td>
            <td><%= alert[:alert_type] %></td>
            <td><%= alert[:severity] %></td>
            <td><%= alert[:message].to_s[0, 80] %><%= alert[:message].to_s.length > 80 ? '…' : '' %></td>
            <td><%= alert[:status] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
