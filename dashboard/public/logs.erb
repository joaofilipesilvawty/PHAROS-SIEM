<div class="gf-page-head">
  <h1>Logs de segurança</h1>
  <a class="gf-btn" href="/dashboard">← Dashboard</a>
</div>

<div class="gf-panel">
  <div class="gf-panel-h">Eventos recentes</div>
  <div class="gf-panel-b gf-table-wrap">
    <table class="gf-table">
      <thead>
        <tr>
          <th>Data</th>
          <th>Evento</th>
          <th>Severidade</th>
          <th>Utilizador</th>
          <th>IP</th>
          <th>Mensagem</th>
        </tr>
      </thead>
      <tbody>
        <% (@logs || []).each do |log| %>
          <tr>
            <td><%= log[:timestamp] ? log[:timestamp].strftime('%Y-%m-%d %H:%M') : '-' %></td>
            <td><%= log[:event_type] %></td>
            <td><%= log[:severity] %></td>
            <td><%= log[:user_id] %></td>
            <td><%= log[:ip_address] %></td>
            <td><%= log[:message].to_s[0, 60] %><%= log[:message].to_s.length > 60 ? '…' : '' %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
