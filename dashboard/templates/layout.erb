<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="description" content="SIEM Dashboard - Sistema de Monitoramento de Segurança">
    <meta name="author" content="SIEM Team">
    <meta name="robots" content="noindex, nofollow">
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https://cdn.jsdelivr.net; font-src 'self' https://cdn.jsdelivr.net;">
    <title>SIEM Dashboard - Monitoramento de Segurança</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css" rel="stylesheet">
    <link href="/dashboard/css/style.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar" class="bg-dark">
            <div class="sidebar-header bg-dark">
                <div class="d-flex align-items-center justify-content-between p-3">
                    <h3 class="mb-0 text-white">SIEM Dashboard</h3>
                    <button type="button" id="sidebarCollapse" class="btn btn-dark d-lg-none">
                        <i class='bx bx-menu'></i>
                    </button>
                </div>
            </div>
            <ul class="list-unstyled components">
                <li class="<%= request.path == '/dashboard' ? 'active' : '' %>">
                    <a href="/dashboard" class="text-white">
                        <i class='bx bxs-dashboard'></i> Dashboard
                    </a>
                </li>
                <li class="<%= request.path == '/dashboard/alerts' ? 'active' : '' %>">
                    <a href="/dashboard/alerts" class="text-white">
                        <i class='bx bxs-bell'></i> Alertas
                        <span class="badge bg-danger ms-2" id="alertCount">0</span>
                    </a>
                </li>
                <li class="<%= request.path == '/dashboard/logs' ? 'active' : '' %>">
                    <a href="/dashboard/logs" class="text-white">
                        <i class='bx bxs-file'></i> Logs
                    </a>
                </li>
                <li class="<%= request.path == '/dashboard/metrics' ? 'active' : '' %>">
                    <a href="/dashboard/metrics" class="text-white">
                        <i class='bx bxs-chart'></i> Métricas
                    </a>
                </li>
                <li class="<%= request.path == '/dashboard/reports' ? 'active' : '' %>">
                    <a href="/dashboard/reports" class="text-white">
                        <i class='bx bxs-report'></i> Relatórios
                    </a>
                </li>
                <li class="<%= request.path == '/dashboard/settings' ? 'active' : '' %>">
                    <a href="/dashboard/settings" class="text-white">
                        <i class='bx bxs-cog'></i> Configurações
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Page Content -->
        <div id="content">
            <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
                <div class="container-fluid">
                    <div class="d-flex align-items-center">
                        <button type="button" id="sidebarCollapse" class="btn btn-link d-none d-lg-block">
                            <i class='bx bx-menu'></i>
                        </button>
                        <div class="ms-3">
                            <h5 class="mb-0 text-dark" id="pageTitle">Dashboard</h5>
                        </div>
                    </div>
                    <div class="d-flex align-items-center">
                        <div class="dropdown me-3">
                            <button class="btn btn-link dropdown-toggle" type="button" id="timeRangeDropdown" data-bs-toggle="dropdown">
                                <i class='bx bx-calendar'></i> <span id="selectedTimeRange">Últimas 24h</span>
                            </button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="#" data-range="1h">Última hora</a></li>
                                <li><a class="dropdown-item" href="#" data-range="24h">Últimas 24h</a></li>
                                <li><a class="dropdown-item" href="#" data-range="7d">Últimos 7 dias</a></li>
                                <li><a class="dropdown-item" href="#" data-range="30d">Últimos 30 dias</a></li>
                                <li><a class="dropdown-item" href="#" data-range="custom">Personalizado</a></li>
                            </ul>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-link dropdown-toggle" type="button" id="userDropdown" data-bs-toggle="dropdown">
                                <i class='bx bxs-user-circle'></i> <span id="userName">Usuário</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/dashboard/profile"><i class='bx bxs-user'></i> Perfil</a></li>
                                <li><a class="dropdown-item" href="/dashboard/settings"><i class='bx bxs-cog'></i> Configurações</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/logout"><i class='bx bx-log-out'></i> Sair</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="container-fluid py-4">
                <%= yield %>
            </div>
        </div>
    </div>

    <!-- Loading Spinner -->
    <div id="loadingSpinner" class="position-fixed top-50 start-50 translate-middle d-none">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Carregando...</span>
        </div>
    </div>

    <!-- Toast Notifications -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="toast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class='bx bx-bell me-2'></i>
                <strong class="me-auto">Notificação</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body"></div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/moment/moment.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>
    <script src="/dashboard/js/main.js"></script>
</body>
</html>