<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="card-title mb-0">Gerar Relatório</h5>
                    </div>
                    <form id="reportForm" class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Tipo de Relatório</label>
                            <select class="form-select" name="report_type" required>
                                <% @report_types.each do |type| %>
                                    <option value="<%= type[:id] %>"><%= type[:name] %></option>
                                <% end %>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Período</label>
                            <input type="text" class="form-control" id="dateRange" name="dateRange" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Formato</label>
                            <select class="form-select" name="format" required>
                                <option value="pdf">PDF</option>
                                <option value="csv">CSV</option>
                                <option value="xlsx">Excel</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">
                                <i class='bx bx-file'></i> Gerar Relatório
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="card-title mb-0">Relatórios Gerados</h5>
                        <button class="btn btn-outline-secondary" id="refreshReports">
                            <i class='bx bx-refresh'></i> Atualizar
                        </button>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Nome</th>
                                    <th>Tipo</th>
                                    <th>Período</th>
                                    <th>Formato</th>
                                    <th>Data de Geração</th>
                                    <th>Status</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Incidentes_Seguranca_2024_03</td>
                                    <td>Incidentes de Segurança</td>
                                    <td>01/03/2024 - 31/03/2024</td>
                                    <td>PDF</td>
                                    <td>01/04/2024 00:01</td>
                                    <td><span class="badge bg-success">Concluído</span></td>
                                    <td>
                                        <div class="btn-group">
                                            <button class="btn btn-sm btn-outline-primary">
                                                <i class='bx bx-download'></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger">
                                                <i class='bx bx-trash'></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Performance_Sistema_Q1_2024</td>
                                    <td>Performance do Sistema</td>
                                    <td>01/01/2024 - 31/03/2024</td>
                                    <td>Excel</td>
                                    <td>01/04/2024 00:05</td>
                                    <td><span class="badge bg-success">Concluído</span></td>
                                    <td>
                                        <div class="btn-group">
                                            <button class="btn btn-sm btn-outline-primary">
                                                <i class='bx bx-download'></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger">
                                                <i class='bx bx-trash'></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Atividade_Usuarios_Abril_2024</td>
                                    <td>Atividade dos Usuários</td>
                                    <td>01/04/2024 - 30/04/2024</td>
                                    <td>PDF</td>
                                    <td>01/05/2024 00:01</td>
                                    <td><span class="badge bg-warning">Gerando</span></td>
                                    <td>
                                        <div class="btn-group">
                                            <button class="btn btn-sm btn-outline-primary" disabled>
                                                <i class='bx bx-download'></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" disabled>
                                                <i class='bx bx-trash'></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialize date range picker
    $('#dateRange').daterangepicker({
        locale: {
            format: 'DD/MM/YYYY'
        }
    });

    // Handle report generation
    $('#reportForm').on('submit', function(e) {
        e.preventDefault();
        const formData = new FormData(this);

        // Show loading state
        const submitBtn = this.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<i class="bx bx-loader bx-spin"></i> Gerando...';
        submitBtn.disabled = true;

        // Simulate report generation (replace with actual API call)
        setTimeout(() => {
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;

            // Show success message
            const toast = new bootstrap.Toast(document.getElementById('toast'));
            document.querySelector('.toast-body').textContent = 'Relatório iniciado com sucesso! Você será notificado quando estiver pronto.';
            toast.show();
        }, 2000);
    });

    // Handle report refresh
    $('#refreshReports').on('click', function() {
        location.reload();
    });

    // Handle report download
    document.querySelectorAll('.btn-outline-primary:not([disabled])').forEach(btn => {
        btn.addEventListener('click', function() {
            // Implement download logic here
        });
    });

    // Handle report deletion
    document.querySelectorAll('.btn-outline-danger:not([disabled])').forEach(btn => {
        btn.addEventListener('click', function() {
            if (confirm('Tem certeza que deseja excluir este relatório?')) {
                // Implement deletion logic here
            }
        });
    });
});
</script>