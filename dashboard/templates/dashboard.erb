<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SIEM Dashboard</title>
    <link rel="stylesheet" href="/css/dashboard.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="dashboard-grid">
        <!-- Métricas de Severidade -->
        <div class="metrics card">
            <div class="metric-card">
                <div class="metric-value status-critical"><%= @metrics[:critical_count] || 0 %></div>
                <div class="metric-label">Critical</div>
            </div>
            <div class="metric-card">
                <div class="metric-value status-high"><%= @metrics[:high_count] || 0 %></div>
                <div class="metric-label">High</div>
            </div>
            <div class="metric-card">
                <div class="metric-value status-medium"><%= @metrics[:medium_count] || 0 %></div>
                <div class="metric-label">Medium</div>
            </div>
            <div class="metric-card">
                <div class="metric-value status-low"><%= @metrics[:low_count] || 0 %></div>
                <div class="metric-label">Low</div>
            </div>
        </div>

        <!-- Gráficos de Sistema -->
        <div class="gauges card">
            <div class="gauge">
                <canvas id="cpuGauge"></canvas>
            </div>
            <div class="gauge">
                <canvas id="memoryGauge"></canvas>
            </div>
            <div class="gauge">
                <canvas id="diskGauge"></canvas>
            </div>
        </div>

        <!-- Alertas Recentes -->
        <div class="table-container card">
            <h2>Recent Alerts</h2>
            <table>
                <thead>
                    <tr>
                        <th>Severity</th>
                        <th>Type</th>
                        <th>Message</th>
                        <th>Time</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% @alerts.each do |alert| %>
                    <tr>
                        <td><span class="status status-<%= alert[:severity].downcase %>"><%= alert[:severity] %></span></td>
                        <td><%= alert[:alert_type] %></td>
                        <td><%= alert[:message] %></td>
                        <td><%= alert[:timestamp] %></td>
                        <td><%= alert[:status] %></td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
        </div>

        <!-- Logs Recentes -->
        <div class="table-container card">
            <h2>Recent Logs</h2>
            <table>
                <thead>
                    <tr>
                        <th>Event Type</th>
                        <th>Source</th>
                        <th>Message</th>
                        <th>Time</th>
                        <th>User ID</th>
                        <th>IP Address</th>
                    </tr>
                </thead>
                <tbody>
                    <% @logs.each do |log| %>
                    <tr>
                        <td><%= log[:event_type] %></td>
                        <td><%= log[:source] %></td>
                        <td><%= log[:message] %></td>
                        <td><%= log[:timestamp] %></td>
                        <td><%= log[:user_id] %></td>
                        <td><%= log[:ip_address] %></td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
        </div>

        <!-- Gráfico de Atividade -->
        <div class="chart-container card">
            <h2>Activity Timeline</h2>
            <canvas id="activityChart"></canvas>
        </div>
    </div>

    <script>
        // Configuração dos gráficos circulares
        function createGauge(elementId, value, label, color) {
            new Chart(document.getElementById(elementId), {
                type: 'doughnut',
                data: {
                    datasets: [{
                        data: [value, 100 - value],
                        backgroundColor: [color, '#2a2e32']
                    }]
                },
                options: {
                    cutout: '70%',
                    responsive: true,
                    plugins: {
                        legend: { display: false },
                        title: {
                            display: true,
                            text: `${label}: ${value}%`,
                            color: '#ffffff'
                        }
                    }
                }
            });
        }

        // Criar gráficos circulares
        createGauge('cpuGauge', <%= @metrics[:cpu_usage] || 0 %>, 'CPU', '#28a745');
        createGauge('memoryGauge', <%= @metrics[:memory_usage] || 0 %>, 'Memory', '#fd7e14');
        createGauge('diskGauge', <%= @metrics[:disk_usage] || 0 %>, 'Disk', '#007bff');

        // Gráfico de linha para atividade
        new Chart(document.getElementById('activityChart'), {
            type: 'line',
            data: {
                labels: <%= @activity_timeline[:labels].to_json %>,
                datasets: [{
                    label: 'Events',
                    data: <%= @activity_timeline[:data].to_json %>,
                    borderColor: '#007bff',
                    tension: 0.4,
                    fill: false
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false },
                    title: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: '#32383e'
                        },
                        ticks: {
                            color: '#8b949e'
                        }
                    },
                    x: {
                        grid: {
                            color: '#32383e'
                        },
                        ticks: {
                            color: '#8b949e'
                        }
                    }
                }
            }
        });
    </script>
</body>
</html>