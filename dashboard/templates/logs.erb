document.addEventListener('DOMContentLoaded', function() {
    // Initialize date range picker
    $('#dateRange').daterangepicker({
        locale: {
            format: 'DD/MM/YYYY'
        }
    });

    // Handle log filters
    $('#logFilters').on('submit', function(e) {
        e.preventDefault();
        // Implement filter logic here
    });

    // Handle log refresh
    $('#refreshLogs').on('click', function() {
        location.reload();
    });

    // Handle log details view
    $('.view-log').on('click', function() {
        const logId = $(this).closest('tr').data('log-id');
        // Implement log details fetch logic here
    });

    // Handle export
    $('[data-export]').on('click', function(e) {
        e.preventDefault();
        const format = $(this).data('export');
        // Implement export logic here
    });
});
</script>